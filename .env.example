# Copia este archivo como .env.
FOOTBALL_SOURCE=api-football

# Opcion A: Football-Data.co.uk sin API key
FOOTBALL_DATA_FIXTURES_URL=https://www.football-data.co.uk/fixtures.csv
FOOTBALL_DATA_HISTORY_URL=https://www.football-data.co.uk/mmz4281/{season}/{league}.csv
FOOTBALL_DATA_LEAGUES=

# Opcion B: API-FOOTBALL
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io
FOOTBALL_API_KEY=
FOOTBALL_API_TIMEOUT=20
FOOTBALL_SEASON=2026
FOOTBALL_LEAGUES=2,3,39,140,135,78,281,11,13
API_FOOTBALL_LEAGUES=2,3,39,140,135,78,281,11,13
API_FOOTBALL_SEASONS_BY_LEAGUE=2:2025,3:2025,39:2025,140:2025,135:2025,78:2025,281:2026,11:2026,13:2026
API_FOOTBALL_PREMIUM_CONTEXT=true

# Opcion C: archivo local real con partidos y stats
FOOTBALL_DATA_FILE=

# Betano
BETANO_URL=https://www.betano.pe/
BETANO_HEADLESS=true
BETANO_TIMEOUT_MS=25000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/apuestas

# API / Dashboard
API_URL=http://127.0.0.1:8000
MIN_EV=0.02
